{
  "id": "upscale-image",
  "name": "Upscale Image",
  "description": "Enhance resolution of existing image using AI upscaler",
  "vramRequired": 4,
  "estimatedTime": "5-10s",
  "workflow": {
    "1": {
      "class_type": "LoadImage",
      "inputs": {
        "image": "{{input_image}}"
      }
    },
    "2": {
      "class_type": "UpscaleModelLoader",
      "inputs": {
        "model_name": "4x-UltraSharp.pth"
      }
    },
    "3": {
      "class_type": "ImageUpscaleWithModel",
      "inputs": {
        "upscale_model": [
          "2",
          0
        ],
        "image": [
          "1",
          0
        ]
      }
    },
    "9": {
      "class_type": "SaveImage",
      "inputs": {
        "filename_prefix": "flowcut_upscaled",
        "images": [
          "3",
          0
        ]
      }
    }
  },
  "params": {
    "input_image": "string"
  }
}