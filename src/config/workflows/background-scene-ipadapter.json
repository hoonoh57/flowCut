{
  "id": "background-scene-ipadapter",
  "name": "Background Scene + IPAdapter Face (SDXL)",
  "description": "Generate image with IPAdapter face reference for character consistency",
  "engine": "comfyui",
  "vramRequired": 8,
  "estimatedTime": "15-30s",
  "workflow": {
    "4": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": {
        "ckpt_name": "DreamShaperXL_Turbo_v2.safetensors"
      }
    },
    "5": {
      "class_type": "EmptyLatentImage",
      "inputs": {
        "width": 1024,
        "height": 1024,
        "batch_size": 1
      }
    },
    "6": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "{{positive}}",
        "clip": ["4", 1]
      }
    },
    "7": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "{{negative}}",
        "clip": ["4", 1]
      }
    },
    "10": {
      "class_type": "IPAdapterUnifiedLoader",
      "inputs": {
        "preset": "PLUS FACE (portraits)",
        "model": ["4", 0]
      }
    },
    "11": {
      "class_type": "LoadImage",
      "inputs": {
        "image": "{{face_ref}}"
      }
    },
    "20": {
      "class_type": "IPAdapter",
      "inputs": {
        "weight": 0.7,
        "start_at": 0.0,
        "end_at": 0.85,
        "weight_type": "style transfer precise",
        "model": ["10", 0],
        "ipadapter": ["10", 1],
        "image": ["11", 0]
      }
    },
    "3": {
      "class_type": "KSampler",
      "inputs": {
        "seed": -1,
        "steps": 8,
        "cfg": 2,
        "sampler_name": "euler",
        "scheduler": "sgm_uniform",
        "denoise": 1,
        "model": ["20", 0],
        "positive": ["6", 0],
        "negative": ["7", 0],
        "latent_image": ["5", 0]
      }
    },
    "8": {
      "class_type": "VAEDecode",
      "inputs": {
        "samples": ["3", 0],
        "vae": ["4", 2]
      }
    },
    "9": {
      "class_type": "SaveImage",
      "inputs": {
        "filename_prefix": "flowcut_ipa",
        "images": ["8", 0]
      }
    }
  },
  "params": {
    "positive": "string",
    "negative": "string?",
    "face_ref": "string",
    "seed": "number?"
  }
}
