{
    "id":  "video-i2v",
    "name":  "Image to Video (Wan2.2 5B + CausVid)",
    "description":  "Animate a reference image into 2-second video clip",
    "engine":  "comfyui",
    "vramRequired":  6,
    "estimatedTime":  "30-60s",
    "outputType":  "video",
    "workflow":  {
                     "3":  {
                               "class_type":  "KSampler",
                               "inputs":  {
                                              "seed":  -1,
                                              "steps":  8,
                                              "cfg":  1,
                                              "sampler_name":  "uni_pc",
                                              "scheduler":  "simple",
                                              "denoise":  1,
                                              "model":  [
                                                            "48",
                                                            0
                                                        ],
                                              "positive":  [
                                                               "6",
                                                               0
                                                           ],
                                              "negative":  [
                                                               "7",
                                                               0
                                                           ],
                                              "latent_image":  [
                                                                   "55",
                                                                   0
                                                               ]
                                          }
                           },
                     "6":  {
                               "class_type":  "CLIPTextEncode",
                               "inputs":  {
                                              "text":  "{{positive}}",
                                              "clip":  [
                                                           "60",
                                                           1
                                                       ]
                                          }
                           },
                     "7":  {
                               "class_type":  "CLIPTextEncode",
                               "inputs":  {
                                              "text":  "blurry, overexposed, static, subtitle, worst quality, low quality, JPEG artifacts, ugly, deformed, still frame, text, watermark",
                                              "clip":  [
                                                           "60",
                                                           1
                                                       ]
                                          }
                           },
                     "8":  {
                               "class_type":  "VAEDecode",
                               "inputs":  {
                                              "samples":  [
                                                              "3",
                                                              0
                                                          ],
                                              "vae":  [
                                                          "39",
                                                          0
                                                      ]
                                          }
                           },
                     "10":  {
                                "class_type":  "LoadImage",
                                "inputs":  {
                                               "image":  "{{start_image}}"
                                           }
                            },
                     "28":  {
                                "class_type":  "VHS_VideoCombine",
                                "inputs":  {
                                               "images":  [
                                                              "8",
                                                              0
                                                          ],
                                               "frame_rate":  16,
                                               "loop_count":  0,
                                               "filename_prefix":  "flowcut_i2v",
                                               "format":  "video/h264-mp4",
                                               "pingpong":  false,
                                               "save_output":  true
                                           }
                            },
                     "37":  {
                                "class_type":  "UNETLoader",
                                "inputs":  {
                                               "unet_name":  "wan2.2_ti2v_5B_fp16.safetensors",
                                               "weight_dtype":  "default"
                                           }
                            },
                     "38":  {
                                "class_type":  "CLIPLoader",
                                "inputs":  {
                                               "clip_name":  "umt5_xxl_fp8_e4m3fn_scaled.safetensors",
                                               "type":  "wan",
                                               "device":  "default"
                                           }
                            },
                     "39":  {
                                "class_type":  "VAELoader",
                                "inputs":  {
                                               "vae_name":  "wan2.2_vae.safetensors"
                                           }
                            },
                     "48":  {
                                "class_type":  "ModelSamplingSD3",
                                "inputs":  {
                                               "shift":  8,
                                               "model":  [
                                                             "60",
                                                             0
                                                         ]
                                           }
                            },
                     "55":  {
                                "class_type":  "Wan22ImageToVideoLatent",
                                "inputs":  {
                                               "vae":  [
                                                           "39",
                                                           0
                                                       ],
                                               "start_image":  [
                                                                   "10",
                                                                   0
                                                               ],
                                               "width":  480,
                                               "height":  480,
                                               "length":  81,
                                               "batch_size":  1
                                           }
                            },
                     "60":  {
                                "class_type":  "LoraLoader",
                                "inputs":  {
                                               "lora_name":  "Wan21_CausVid_14B_T2V_lora_rank32.safetensors",
                                               "strength_model":  0.35,
                                               "strength_clip":  0.35,
                                               "model":  [
                                                             "37",
                                                             0
                                                         ],
                                               "clip":  [
                                                            "38",
                                                            0
                                                        ]
                                           }
                            }
                 },
    "params":  {
                   "positive":  "string",
                   "negative":  "string?",
                   "start_image":  "string",
                   "width":  "number?",
                   "height":  "number?",
                   "length":  "number?",
                   "steps":  "number?"
               }
}